# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
# Route sign-up attempts to sign-in; access is invite-only via admin invitations.
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
NEXT_PUBLIC_CLERK_USER_PROFILE_URL=/account
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/sign-in

# Neon Postgres
DATABASE_URL=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@jawaninvestments.com

# Cron secret
CRON_SECRET=

# Bootstrap super admin
# Email of the first user to sign in becomes the permanent super admin (full access,
# cannot be demoted by other admins). Set this before the first sign-in and rotate by
# updating the User.isSuperAdmin flag directly in the database if ownership changes.
SUPER_ADMIN_EMAIL=

# Google Gemini — powers the private financial assistant (free tier available)
# Get a key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional model override (default: gemini-2.5-flash-lite)
GEMINI_MODEL=

# GoldAPI.io — optional; live gold/silver falls back to CoinGecko when unset
GOLD_API_KEY=
