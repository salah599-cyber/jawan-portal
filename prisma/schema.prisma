  updatedAt             DateTime                  @updatedAt

  @@index([entityId, status])
  @@index([expiryDate])
  @@index([policyType])
  @@index([policyNumber])
}

model InsurancePolicyDocument {
  id           String                @id @default(cuid())
  policyId     String
  policy       InsurancePolicy       @relation(fields: [policyId], references: [id], onDelete: Cascade)
  documentType InsuranceDocumentType @default(OTHER)
  fileName     String
  fileUrl      String
  mimeType     String
  fileSize     Int
  notes        String?
  uploadedById String?
  createdAt    DateTime              @default(now())

  @@index([policyId, documentType])
}

// --- Family Members & Beneficiaries ---

enum FamilyRelationship {
  HEAD_OF_FAMILY
  SPOUSE
  SON
  DAUGHTER
  CHILD
  PARENT
  SIBLING
  GRANDCHILD
  OTHER
}

enum FamilyMemberIdType {
  OMANI_ID
  PASSPORT
  RESIDENCE_CARD
  OTHER
}

enum FamilyKycStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
  EXPIRED
}

enum FamilyMemberDocumentType {
  PASSPORT
  NATIONAL_ID
  RESIDENCE
  PROOF_OF_ADDRESS
  BIRTH_CERTIFICATE
  POA
  OTHER
}

enum FamilyOwnershipStakeType {
  ECONOMIC
  LEGAL_TITLE
  BENEFICIAL
}

enum FamilySignatoryRoleType {
  BANK_SIGNATORY
  COMPANY_DIRECTOR
  CHEQUE_SIGNATORY
  POA_HOLDER
  OTHER
}

enum BeneficiaryDesignationType {
  PRIMARY
  CONTINGENT
  SPECIFIC_BEQUEST
}

model FamilyMember {
  id                    String                  @id @default(cuid())
  fullName              String
  preferredName         String?
  dateOfBirth           DateTime?
  nationality           String?
  relationship          FamilyRelationship?
  idType                FamilyMemberIdType?
  idNumber              String?
  idExpiryDate          DateTime?
  kycStatus             FamilyKycStatus         @default(NOT_STARTED)
  kycNotes              String?
  email                 String?
  phonePrimary          String?
  phoneSecondary        String?
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  isBeneficiary         Boolean                 @default(false)
  deceased              Boolean                 @default(false)
  dateOfDeath           DateTime?
  userId                String?                 @unique
  user                  User?                   @relation("FamilyMemberUser", fields: [userId], references: [id], onDelete: SetNull)
  notes                 String?
  emails                FamilyMemberEmail[]
  phones                FamilyMemberPhone[]
  documents             FamilyMemberDocument[]
  ownershipStakes       FamilyOwnershipStake[]
  signatoryRoles        FamilySignatoryRole[]
  beneficiaryDesignations BeneficiaryDesignation[]
  successionAppointments SuccessionAppointment[]
  successionDistributionsAsBeneficiary SuccessionDistributionInstruction[] @relation("SuccessionBeneficiary")
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([fullName])
  @@index([kycStatus])
  @@index([isBeneficiary])
}

model FamilyMemberEmail {
  id             String       @id @default(cuid())
  familyMemberId String
  familyMember   FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  email          String
  label          String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([familyMemberId])
}

model FamilyMemberPhone {
  id             String       @id @default(cuid())
  familyMemberId String
  familyMember   FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  phone          String
  label          String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([familyMemberId])
}

model FamilyMemberDocument {
  id             String                   @id @default(cuid())
  familyMemberId String
  familyMember   FamilyMember             @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  documentType   FamilyMemberDocumentType @default(OTHER)
  fileName       String
  fileUrl        String
  mimeType       String
  fileSize       Int
  expiryDate     DateTime?
  notes          String?
  uploadedById   String?
  createdAt      DateTime                 @default(now())

  @@index([familyMemberId, documentType])
}

model FamilyOwnershipStake {
  id                  String                   @id @default(cuid())
  familyMemberId      String
  familyMember        FamilyMember             @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  entityId            String?
  entity              Entity?                  @relation(fields: [entityId], references: [id], onDelete: SetNull)
  assetId             String?
  asset               Asset?                   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  landParcelId        String?
  landParcel          LandParcel?              @relation(fields: [landParcelId], references: [id], onDelete: SetNull)
  registeredCompanyId String?
  registeredCompany   RegisteredCompany?       @relation(fields: [registeredCompanyId], references: [id], onDelete: SetNull)
  rePropertyId        String?
  reProperty          ReProperty?              @relation(fields: [rePropertyId], references: [id], onDelete: SetNull)
  vehicleId           String?
  vehicle             Vehicle?                 @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  stakeType           FamilyOwnershipStakeType @default(ECONOMIC)
  ownershipPct        Decimal?                 @db.Decimal(5, 2)
  roleLabel           String?
  notes               String?
  sortOrder           Int                      @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([familyMemberId])
  @@index([entityId])
}

model FamilySignatoryRole {
  id                  String                  @id @default(cuid())
  familyMemberId      String
  familyMember        FamilyMember            @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  entityId            String
  entity              Entity                  @relation(fields: [entityId], references: [id])
  registeredCompanyId String?
  registeredCompany   RegisteredCompany?      @relation(fields: [registeredCompanyId], references: [id], onDelete: SetNull)
  assetId             String?
  asset               Asset?                  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  vehicleId           String?
  vehicle             Vehicle?                @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  roleType            FamilySignatoryRoleType @default(OTHER)
  bankName            String?
  accountRef          String?
  effectiveFrom       DateTime?
  effectiveTo         DateTime?
  isActive            Boolean                 @default(true)
  notes               String?
  sortOrder           Int                     @default(0)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  accounts            FamilySignatoryAccount[]

  @@index([familyMemberId])
  @@index([entityId])
}

model FamilySignatoryAccount {
  id                    String              @id @default(cuid())
  familySignatoryRoleId String
  familySignatoryRole   FamilySignatoryRole @relation(fields: [familySignatoryRoleId], references: [id], onDelete: Cascade)
  accountNumber         String
  currency              String              @default("OMR")
  label                 String?
  sortOrder             Int                 @default(0)
  createdAt             DateTime            @default(now())

  @@index([familySignatoryRoleId])
}

model BeneficiaryDesignation {
  id                  String                     @id @default(cuid())
  familyMemberId      String
  familyMember        FamilyMember               @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  insurancePolicyId   String?
  insurancePolicy     InsurancePolicy?           @relation(fields: [insurancePolicyId], references: [id], onDelete: SetNull)
  assetId             String?
  asset               Asset?                     @relation(fields: [assetId], references: [id], onDelete: SetNull)
  landParcelId        String?
  landParcel          LandParcel?                @relation(fields: [landParcelId], references: [id], onDelete: SetNull)
  registeredCompanyId String?
  registeredCompany   RegisteredCompany?         @relation(fields: [registeredCompanyId], references: [id], onDelete: SetNull)
  rePropertyId        String?
  reProperty          ReProperty?                @relation(fields: [rePropertyId], references: [id], onDelete: SetNull)
  vehicleId           String?
  vehicle             Vehicle?                   @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  designationType     BeneficiaryDesignationType @default(PRIMARY)
  allocationPct       Decimal?                   @db.Decimal(5, 2)
  effectiveDate       DateTime?
  notes               String?
  sortOrder           Int                        @default(0)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([familyMemberId])
}

// --- Succession & Estate Planning ---

enum SuccessionPlanStatus {
  DRAFT
  IN_PROGRESS
  REVIEW_DUE
  COMPLETE
}

enum SuccessionAppointmentRole {
  EXECUTOR
  TRUSTEE
  GUARDIAN
  POA_AGENT
  ADVISOR
}

enum SuccessionDocumentType {
  WILL
  TRUST_DEED
  LETTER_OF_WISHES
  POA
  LIVING_WILL
  OTHER
}

enum SuccessionDocumentStatus {
  DRAFT
  SIGNED
  FILED
  MISSING
}

model SuccessionPlan {
  id                    String                            @id @default(cuid())
  title                 String
  status                SuccessionPlanStatus              @default(DRAFT)
  entityId              String?
  entity                Entity?                           @relation(fields: [entityId], references: [id], onDelete: SetNull)
  generalInstructions   String?
  incapacitationNotes   String?
  lastReviewDate        DateTime?
  nextReviewDate        DateTime?
  notes                 String?
  distributionInstructions SuccessionDistributionInstruction[]
  appointments          SuccessionAppointment[]
  documents             SuccessionPlanDocument[]
  checklistItems        SuccessionChecklistItem[]
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt

  @@index([status])
  @@index([nextReviewDate])
}

model SuccessionDistributionInstruction {
  id                   String         @id @default(cuid())
  successionPlanId     String
  successionPlan       SuccessionPlan @relation(fields: [successionPlanId], references: [id], onDelete: Cascade)
  beneficiaryMemberId  String?
  beneficiaryMember    FamilyMember?  @relation("SuccessionBeneficiary", fields: [beneficiaryMemberId], references: [id], onDelete: SetNull)
  entityId             String?
  entity               Entity?        @relation(fields: [entityId], references: [id], onDelete: SetNull)
  assetId              String?
  asset                Asset?         @relation(fields: [assetId], references: [id], onDelete: SetNull)
  landParcelId         String?
  landParcel           LandParcel?    @relation(fields: [landParcelId], references: [id], onDelete: SetNull)
  registeredCompanyId  String?
  registeredCompany    RegisteredCompany? @relation(fields: [registeredCompanyId], references: [id], onDelete: SetNull)
  rePropertyId         String?
  reProperty           ReProperty?    @relation(fields: [rePropertyId], references: [id], onDelete: SetNull)
  vehicleId            String?
  vehicle              Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  allocationPct        Decimal?       @db.Decimal(5, 2)
  allocationAmount     Decimal?       @db.Decimal(18, 2)
  currency             String         @default("OMR")
  instructions         String?
  sortOrder            Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([successionPlanId])
}

model SuccessionAppointment {
  id               String                    @id @default(cuid())
  successionPlanId String
  successionPlan   SuccessionPlan            @relation(fields: [successionPlanId], references: [id], onDelete: Cascade)
  familyMemberId   String
  familyMember     FamilyMember              @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  role             SuccessionAppointmentRole
  isPrimary        Boolean                   @default(false)
  notes            String?
  sortOrder        Int                       @default(0)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([successionPlanId])
}

model SuccessionPlanDocument {
  id               String                   @id @default(cuid())
  successionPlanId String
  successionPlan   SuccessionPlan           @relation(fields: [successionPlanId], references: [id], onDelete: Cascade)
  documentType     SuccessionDocumentType   @default(OTHER)
  status           SuccessionDocumentStatus @default(MISSING)
  fileName         String?
  fileUrl          String?
  mimeType         String?
  fileSize         Int?
  signedDate       DateTime?
  jurisdiction     String?
  notes            String?
  uploadedById     String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([successionPlanId, documentType])
}

model SuccessionChecklistItem {
  id               String         @id @default(cuid())
  successionPlanId String
  successionPlan   SuccessionPlan @relation(fields: [successionPlanId], references: [id], onDelete: Cascade)
  label            String
  category         String?
  isComplete       Boolean        @default(false)
  dueDate          DateTime?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([successionPlanId])
}

// --- Contacts Directory ---

enum DirectoryContactType {
  BANKER
  LAWYER
  FUND_MANAGER
  BROKER
  TENANT
  CONTRACTOR
  CO_INVESTOR
  GOVERNMENT
  ADVISOR
  OTHER
}

model DirectoryContact {
  id                String               @id @default(cuid())
  fullName          String
  organization      String?
  jobTitle          String?
  contactType       DirectoryContactType @default(OTHER)
  email             String?
  phonePrimary      String?
  phoneSecondary    String?
  address           String?
  city              String?
  country           String?
  website           String?
  entityId          String?
  entity            Entity?              @relation(fields: [entityId], references: [id], onDelete: SetNull)
  notes             String?
  tags              Json                 @default("[]")
  lastContactDate   DateTime?
  nextFollowUpDate  DateTime?
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  emails            DirectoryContactEmail[]
  phones            DirectoryContactPhone[]

  @@index([fullName])
  @@index([contactType])
  @@index([entityId])
  @@index([nextFollowUpDate])
}

model DirectoryContactEmail {
  id                 String           @id @default(cuid())
  directoryContactId String
  directoryContact   DirectoryContact @relation(fields: [directoryContactId], references: [id], onDelete: Cascade)
  email              String
  label              String?
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())

  @@index([directoryContactId])
}

model DirectoryContactPhone {
  id                 String           @id @default(cuid())
  directoryContactId String
  directoryContact   DirectoryContact @relation(fields: [directoryContactId], references: [id], onDelete: Cascade)
  countryCode        String           @default("+968")
  phone              String
  label              String?
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())

  @@index([directoryContactId])
}
