generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PRINCIPAL
  SIGNATORY
  FINANCE
  DIRECTOR
  EXTERNAL
}

enum PermissionLevel {
  FULL
  READ
  FILTERED
  NONE
  SHARED_ONLY
}

enum ModuleName {
  DASHBOARD
  ASSETS
  LANDS
  REAL_ESTATE
  CARS
  COMPANIES
  LOANS
  CHEQUES
  PROPOSALS
  DOCUMENTS
  INSURANCE
  EXPENSES
  REPORTS
  PRIVATE_EQUITY
  FUND_LP
  CASH_MANAGEMENT
  CALENDAR
  USERS
  AUDIT
  FAMILY_MEMBERS
  SUCCESSION
  CONTACTS
}

enum LandDocumentType {
  KROOKI
  MULKIA
  OTHER
}

enum LandLocationType {
  OMAN
  INTERNATIONAL
}

enum LandSaleDocumentType {
  POWER_OF_ATTORNEY
  SPA
  BUYER_ID
  OTHER
}

enum VehicleDocumentType {
  MULKIA
  INSURANCE
  OTHER
}

enum CompanyDocumentType {
  REGISTRATION_COPY
  CHAMBER_COPY
  FINANCIALS
  OTHER
}

enum PublicMarket {
  MSX
  UAE
  SAUDI_ARABIA
  KUWAIT
  BAHRAIN
  QATAR
  USA
  HONG_KONG
  CHINA
  INDIA
  UK
  OTHER
}

enum PublicHoldingSource {
  IMPORT
  MANUAL
}

enum PublicInstrumentType {
  EQUITY
  OPTION
  STRUCTURED_NOTE
  CRYPTO
}

enum PublicOptionType {
  CALL
  PUT
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AssetCategory {
  REAL_ESTATE
  PRIVATE_EQUITY
  FUND_LP
  PUBLIC_EQUITY
  FIXED_ASSET
  BONDS
  CASH
  PRECIOUS_METALS
  OTHER
}

enum AssetStatus {
  ACTIVE
  MONITOR
  EXITED
  DEFERRED
}

enum FixedAssetType {
  VEHICLE
  JEWELRY
  ART
  OTHER
}

enum PreciousMetalType {
  GOLD
  SILVER
}

enum PreciousMetalUnit {
  GRAM
  TOLA_10
  KG
  OZ
}

enum PreciousMetalPriceBasis {
  OMR_BUY
  OMR_SELL
  USD_SPOT_OZ
}

enum LiabilityType {
  MORTGAGE
  LOAN
  CREDIT
  OTHER
}

enum LiabilityStatus {
  ACTIVE
  PAID_OFF
  DEFAULTED
}

enum LoanDocumentType {
  LOAN_AGREEMENT
  PAYMENT_SCHEDULE
  STATEMENT
  OTHER
}

enum LoanPaymentMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
  DIRECT_DEBIT
  OTHER
}

enum InterestCalculationMethod {
  REDUCING_BALANCE
  FIXED_RATE
}

enum ChequeDirection {
  ISSUED
  RECEIVED
}

enum ChequeStatus {
  PENDING
  DEPOSITED
  CLEARED
  BOUNCED
  CANCELLED
  STOPPED
}

enum ChequeDocumentType {
  CHEQUE_COPY
  DEPOSIT_SLIP
  BANK_CONFIRMATION
  OTHER
}

enum TransferLetterType {
  LOCAL
  INTERNATIONAL
  UK
}

enum PaymentFrequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  BULLET
  OTHER
}

enum DocumentStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
  PENDING
  UNDER_REVIEW
}

enum ExpenseStatus {
  PAID
  PENDING
  OVERDUE
}

enum ExpenseAttachmentType {
  INVOICE
  PAYMENT_SLIP
  CHEQUE_COPY
  OTHER
}

enum CashFlowType {
  INFLOW
  OUTFLOW
}

enum ExitType {
  SALE
  TRANSFER
  LIQUIDATION
  WRITE_OFF
  OTHER
}

enum ExitProceedSettlementStatus {
  PENDING
  SETTLED
  NONE
}

enum ProposalStatus {
  DRAFT
  PENDING
  RETURNED
  APPROVED
  REJECTED
}

enum ProposalDecision {
  APPROVED
  REJECTED
  RETURNED
}

enum ProposalDocumentType {
  DECK
  OTHER
}

enum ProposalCommentKind {
  NOTE
  RETURN
  REJECT
  APPROVE
  RESUBMIT
}

enum AssetExitDocumentType {
  SALE_AGREEMENT
  TRANSFER_DEED
  CLOSING_STATEMENT
  OTHER
}

model User {
  id                  String                   @id @default(cuid())
  clerkId             String                   @unique
  email               String                   @unique
  firstName           String?
  lastName            String?
  role                UserRole                 @default(EXTERNAL)
  isSuperAdmin        Boolean                  @default(false)
  isActive            Boolean                  @default(true)
  entityAccess        UserEntityAccess[]
  documentScopes      UserDocumentScope[]
  permissionOverrides UserPermissionOverride[]
  auditLogs           AuditLog[]
  submittedProposals  InvestmentProposal[] @relation("ProposalSubmitter")
  proposalApprovals   ProposalApprover[]   @relation("ProposalApproverUser")
  proposalComments    ProposalComment[]
  bankBalanceEntries  BankBalanceEntry[]
  assignedTasks       Task[]                   @relation("TaskAssignee")
  createdTasks        Task[]                   @relation("TaskCreator")
  completedTasks      Task[]                   @relation("TaskCompleter")
  familyMember        FamilyMember?            @relation("FamilyMemberUser")
  transferLetters     TransferLetter[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
}

model PendingUserInvite {
  id                 String    @id @default(cuid())
  email              String    @unique
  role               UserRole  @default(EXTERNAL)
  isSuperAdmin       Boolean   @default(false)
  entityIds          Json      @default("[]")
  moduleOverrides    Json      @default("{}")
  documentCategories Json      @default("[]")
  clerkInvitationId  String?
  invitedById        String?
  acceptedAt         DateTime?
  createdAt          DateTime  @default(now())
}

model UserEntityAccess {
  id       String @id @default(cuid())
  userId   String
  entityId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity   Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  @@unique([userId, entityId])
}

model UserDocumentScope {
  id         String                 @id @default(cuid())
  userId     String
  categoryId String
  category   DocumentCategoryRecord @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, categoryId])
}

model UserPermissionOverride {
  id     String          @id @default(cuid())
  userId String
  module ModuleName
  level  PermissionLevel
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, module])
}

model Entity {
  id           String             @id @default(cuid())
  name         String             @unique
  description  String?
  assets       Asset[]
  liabilities  Liability[]
  bankAccounts BankAccount[]
  documents    Document[]
  expenses     Expense[]
  landParcels  LandParcel[]
  vehicles     Vehicle[]
  registeredCompanies RegisteredCompany[]
  cheques      Cheque[]
  transferLetters TransferLetter[]
  investmentProposals InvestmentProposal[]
  peCompanies         PeCompany[]
  lpCommitments       LpCommitment[]
  insurancePolicies   InsurancePolicy[]
  reProperties        ReProperty[]
  tasks               Task[]
  familyOwnershipStakes FamilyOwnershipStake[]
  familySignatoryRoles  FamilySignatoryRole[]
  successionPlans       SuccessionPlan[]
  successionDistributionInstructions SuccessionDistributionInstruction[]
  directoryContacts     DirectoryContact[]
  userAccess   UserEntityAccess[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Task {
  id              String       @id @default(cuid())
  title           String
  description     String?
  dueDate         DateTime
  status          TaskStatus   @default(OPEN)
  priority        TaskPriority @default(MEDIUM)
  entityId        String?
  entity          Entity?      @relation(fields: [entityId], references: [id], onDelete: SetNull)
  assigneeId      String?
  assignee        User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  completedAt     DateTime?
  completedById   String?
  completedBy     User?        @relation("TaskCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  completionNotes String?
  reminderDays    Int          @default(1)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  @@index([dueDate, status])
  @@index([assigneeId, status])
  @@index([entityId])
}

model FxRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String   @default("OMR")
  rate         Decimal  @db.Decimal(18, 8)
  effectiveAt  DateTime @default(now())
  updatedById  String?
  createdAt    DateTime @default(now())
  @@unique([fromCurrency, toCurrency, effectiveAt])
}

model Asset {
  id              String                @id @default(cuid())
  name            String
  description     String?
  category        AssetCategory
  status          AssetStatus           @default(ACTIVE)
  exitedAt        DateTime?
  acquisitionDate DateTime?
  acquisitionCost Decimal?              @db.Decimal(18, 2)
  currentValue    Decimal?              @db.Decimal(18, 2)
  currency        String                @default("OMR")
  valueUpdatedAt  DateTime?
  ownershipPct    Decimal               @default(100) @db.Decimal(5, 2)
  entityId        String
  entity          Entity                @relation(fields: [entityId], references: [id])
  assetTypeId     String?
  assetType       AssetType?            @relation(fields: [assetTypeId], references: [id], onDelete: SetNull)
  managerName     String?
  managerEmail    String?
  managerPhone    String?
  managerNotes    String?
  realEstate      RealEstateDetail?
  privateEquity   PrivateEquityDetail?
  fixedAsset      FixedAssetDetail?
  preciousMetal   PreciousMetalDetail?
  bond            BondDetail?
  cash            CashDetail?
  custom          CustomAssetDetail?
  publicHoldings  PublicEquityHolding[]
  valuations      AssetValuation[]
  cashFlows       AssetCashFlow[]
  documents       Document[]
  expenses        Expense[]
  liabilities     Liability[]
  landParcel      LandParcel?
  vehicle         Vehicle?
  registeredCompany RegisteredCompany?
  peCompany         PeCompany?
  lpCommitment      LpCommitment?
  reProperty        ReProperty?
  exit            AssetExit?
  familyOwnershipStakes FamilyOwnershipStake[]
  familySignatoryRoles  FamilySignatoryRole[]
  beneficiaryDesignations BeneficiaryDesignation[]
  successionDistributionInstructions SuccessionDistributionInstruction[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  @@index([entityId, category, status])
  @@index([assetTypeId])
}

model AssetType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  assets    Asset[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RealEstateDetail {
  id          String  @id @default(cuid())
  assetId     String  @unique
  asset       Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  titleDeed   String?
  plotNumber  String?
  bua         String?
  location    String?
  isEmptyLand Boolean @default(false)
}

model LandParcel {
  id               String            @id @default(cuid())
  name             String
  locationType     LandLocationType  @default(OMAN)
  country          String            @default("Oman")
  governorate      String?
  wilayat          String?
  region           String?
  city             String?
  village          String?
  plotNumber       String?
  krookiNumber     String?
  mulkiaNumber     String?
  landUse          String?
  areaSqm          Decimal?       @db.Decimal(18, 2)
  coordinates      String?
  acquisitionDate  DateTime?
  acquisitionCost  Decimal?       @db.Decimal(18, 2)
  currentValue     Decimal?       @db.Decimal(18, 2)
  currency         String         @default("OMR")
  ownershipPct     Decimal        @default(100) @db.Decimal(5, 2)
  registeredHolder String?
  status           AssetStatus    @default(ACTIVE)
  notes            String?
  entityId         String
  entity           Entity         @relation(fields: [entityId], references: [id])
  assetId          String?        @unique
  asset            Asset?         @relation(fields: [assetId], references: [id])
  documents        LandDocument[]
  registeredHolders LandRegisteredHolder[]
  sale             LandSale?
  reProperty       ReProperty?
  insurancePolicies InsurancePolicy[]
  familyOwnershipStakes FamilyOwnershipStake[]
  beneficiaryDesignations BeneficiaryDesignation[]
  successionDistributionInstructions SuccessionDistributionInstruction[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  @@index([entityId, country, status])
  @@index([entityId, governorate, wilayat, status])
}

model LandRegisteredHolder {
  id           String     @id @default(cuid())
  landParcelId String
  landParcel   LandParcel @relation(fields: [landParcelId], references: [id], onDelete: Cascade)
  name         String
  ownershipPct Decimal?   @db.Decimal(5, 2)
  email        String?
  phone        String?
  notes        String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([landParcelId])
}

model LandDocument {
  id           String           @id @default(cuid())
  landParcelId String
  landParcel   LandParcel       @relation(fields: [landParcelId], references: [id], onDelete: Cascade)
  documentType LandDocumentType
  label        String?
  fileName     String
  fileUrl      String
  mimeType     String
  fileSize     Int
  uploadedById String?
  createdAt    DateTime         @default(now())
  @@index([landParcelId, documentType])
}

model LandSale {
  id           String             @id @default(cuid())
  landParcelId String             @unique
  landParcel   LandParcel         @relation(fields: [landParcelId], references: [id], onDelete: Cascade)
  saleDate     DateTime
  soldTo       String
  saleAmount   Decimal            @db.Decimal(18, 2)
  currency     String             @default("OMR")
  notes        String?
  recordedById String?
  documents    LandSaleDocument[]
  assetExit    AssetExit?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model LandSaleDocument {
  id           String               @id @default(cuid())
  landSaleId   String
  landSale     LandSale             @relation(fields: [landSaleId], references: [id], onDelete: Cascade)
  documentType LandSaleDocumentType
  label        String?
  fileName     String
  fileUrl      String
  mimeType     String
  fileSize     Int
  uploadedById String?
  createdAt    DateTime             @default(now())
  @@index([landSaleId, documentType])
}

model Vehicle {
  id                     String            @id @default(cuid())
  name                   String
  plateNumber            String
  plateCode              String?
  governorate            String
  wilayat                String
  make                   String
  model                  String
  modelYear              Int?
  color                  String?
  vehicleClass           String?
  bodyType               String?
  fuelType               String?
  chassisNumber          String?
  engineNumber           String?
  mulkiaNumber           String?
  registeredOwner        String?
  registrationIssueDate  DateTime?
  registrationExpiryDate DateTime?
  insuranceCompany       String?
  insurancePolicyNumber  String?
  insuranceExpiryDate    DateTime?
  acquisitionDate        DateTime?
  acquisitionCost        Decimal?          @db.Decimal(18, 2)
  currentValue           Decimal?          @db.Decimal(18, 2)
  currency               String            @default("OMR")
  ownershipPct           Decimal           @default(100) @db.Decimal(5, 2)
  status                 AssetStatus       @default(ACTIVE)
  notes                  String?
  entityId               String
  entity                 Entity            @relation(fields: [entityId], references: [id])
  assetId                String?           @unique
  asset                  Asset?            @relation(fields: [assetId], references: [id])
  documents              VehicleDocument[]
  insurancePolicies      InsurancePolicy[]
  familyOwnershipStakes FamilyOwnershipStake[]
  familySignatoryRoles  FamilySignatoryRole[]
  beneficiaryDesignations BeneficiaryDesignation[]
  successionDistributionInstructions SuccessionDistributionInstruction[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  @@index([entityId, governorate, status])
  @@index([plateNumber])
}

model VehicleDocument {
  id           String              @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  documentType VehicleDocumentType
  label        String?
  fileName     String
  fileUrl      String
  mimeType     String
  fileSize     Int
  uploadedById String?
  createdAt    DateTime            @default(now())
  @@index([vehicleId, documentType])
}

model RegisteredCompany {
  id                     String              @id @default(cuid())
  name                   String
  registrationNumber     String
  registrationDate       DateTime?
  registrationExpiryDate DateTime?
  ceoName                String?
  ceoEmail               String?
  ceoPhone               String?
  managementContactName  String?
  managementEmail        String?
  managementPhone        String?
  managementNotes        String?
  status                 AssetStatus         @default(ACTIVE)
  notes                  String?
  entityId               String
  entity                 Entity              @relation(fields: [entityId], references: [id])
  assetId                String?             @unique
  asset                  Asset?              @relation(fields: [assetId], references: [id])
  owners                 CompanyOwner[]
  documents              CompanyDocument[]
  insurancePolicies      InsurancePolicy[]
  familyOwnershipStakes FamilyOwnershipStake[]
  familySignatoryRoles  FamilySignatoryRole[]
  beneficiaryDesignations BeneficiaryDesignation[]
  successionDistributionInstructions SuccessionDistributionInstruction[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([entityId, status])
  @@index([registrationNumber])
  @@index([registrationExpiryDate])
}

model CompanyOwner {
  id           String            @id @default(cuid())
  companyId    String
  company      RegisteredCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  ownershipPct Decimal?          @db.Decimal(5, 2)
  email        String?
  phone        String?
  address      String?
  notes        String?
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([companyId])
}

model CompanyDocument {
  id           String              @id @default(cuid())
  companyId    String
  company      RegisteredCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documentType CompanyDocumentType
  label        String?
  fileName     String
  fileUrl      String
  mimeType     String
  fileSize     Int
  uploadedById String?
  createdAt    DateTime            @default(now())

  @@index([companyId, documentType])
}

model PrivateEquityDetail {
  id                 String   @id @default(cuid())
  assetId            String   @unique
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  shareholdingPct    Decimal? @db.Decimal(5, 2)
  valuationMethod    String?
  lastRoundValuation Decimal? @db.Decimal(18, 2)
  followOnRounds     String?
  registeredHolder   String?
  contactName        String?
  contactEmail       String?
  contactPhone       String?
}

model PublicEquityHolding {
  id            String              @id @default(cuid())
  assetId       String
  asset         Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  market        PublicMarket        @default(MSX)
  symbol        String
  name          String?
  quantity      Decimal             @db.Decimal(18, 6)
  costBasis     Decimal?            @db.Decimal(18, 2)
  marketPrice   Decimal?            @db.Decimal(18, 4)
  marketValue   Decimal?            @db.Decimal(18, 2)
  unrealisedPnl Decimal?            @db.Decimal(18, 2)
  priceFetchedAt DateTime?
  priceSource   String?
  broker        String?
  accountNumber String?
  exchange      String?
  isin          String?
  cusip         String?
  sedol         String?
  country       String?
  source        PublicHoldingSource @default(IMPORT)
  instrumentType PublicInstrumentType @default(EQUITY)
  currency      String              @default("USD")
  asOfDate      DateTime?
  importBatchId String?
  importBatch   ImportBatch?        @relation(fields: [importBatchId], references: [id])
  optionDetail  PublicOptionDetail?
  structuredNoteDetail PublicStructuredNoteDetail?
  cryptoDetail  PublicCryptoDetail?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  @@index([assetId, symbol])
  @@index([assetId, market])
  @@index([market])
  @@index([instrumentType])
}

model PublicOptionDetail {
  id                 String              @id @default(cuid())
  holdingId          String              @unique
  holding            PublicEquityHolding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  underlyingSymbol   String
  optionType         PublicOptionType
  strikePrice        Decimal             @db.Decimal(18, 4)
  expiryDate         DateTime
  contractMultiplier Int                 @default(100)
  premiumPaid        Decimal?            @db.Decimal(18, 2)
}

model PublicStructuredNoteDetail {
  id             String              @id @default(cuid())
  holdingId      String              @unique
  holding        PublicEquityHolding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  issuer         String
  productName    String
  notionalAmount Decimal             @db.Decimal(18, 2)
  issueDate      DateTime?
  maturityDate   DateTime
  couponRate     Decimal?            @db.Decimal(8, 4)
  barrierLevel   Decimal?            @db.Decimal(8, 4)
  payoffNotes    String?
}

model PublicCryptoDetail {
  id          String              @id @default(cuid())
  holdingId   String              @unique
  holding     PublicEquityHolding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  coinGeckoId String
  custodian   String?
}

model FixedAssetDetail {
  id          String         @id @default(cuid())
  assetId     String         @unique
  asset       Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetType   FixedAssetType @default(OTHER)
  condition   String?
  reportNotes String?
}

model PreciousMetalDetail {
  id             String                  @id @default(cuid())
  assetId        String                  @unique
  asset          Asset                   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  metal          PreciousMetalType
  unit           PreciousMetalUnit
  quantity       Decimal                 @db.Decimal(18, 6)
  priceBasis     PreciousMetalPriceBasis @default(OMR_BUY)
  lastUnitPrice  Decimal?                @db.Decimal(18, 6)
  priceFetchedAt DateTime?
  priceSource    String?
}

model BondDetail {
  id              String    @id @default(cuid())
  assetId         String    @unique
  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  issuer          String?
  maturityDate    DateTime?
  couponRate      Decimal?  @db.Decimal(8, 4)
  floorRate       Decimal?  @db.Decimal(8, 4)
  strike          Decimal?  @db.Decimal(18, 4)
  faceValue       Decimal?  @db.Decimal(18, 2)
  shariaCompliant Boolean   @default(false)
}

model CashDetail {
  id            String   @id @default(cuid())
  assetId       String   @unique
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bank          String?
  accountNumber String?
  balance       Decimal? @db.Decimal(18, 2)
}

model CustomAssetDetail {
  id           String @id @default(cuid())
  assetId      String @unique
  asset        Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  customFields Json?
}

model BankAccount {
  id             String              @id @default(cuid())
  entityId       String?
  entity         Entity?             @relation(fields: [entityId], references: [id])
  accountName    String
  bankName       String
  accountNumber  String
  sortCode       String?
  swiftCode      String?
  iban           String?
  currency       String              @default("OMR")
  notes          String?
  currentBalance Decimal?            @db.Decimal(18, 3)
  balanceAsOf    DateTime?
  isActive               Boolean             @default(true)
  includeInCashPosition  Boolean             @default(true)
  isExitSuspense         Boolean             @default(false)
  cheques                Cheque[]
  transferLetters        TransferLetter[]
  beneficiaryTransferLetters TransferLetter[] @relation("TransferLetterBeneficiary")
  balanceEntries BankBalanceEntry[]
  statementImports CashStatementImport[]
  accountNumbers   BankAccountNumber[]
  exitSuspenseProceeds   AssetExit[]         @relation("AssetExitSuspense")
  exitSettledProceeds    AssetExit[]         @relation("AssetExitSettled")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model BankAccountNumber {
  id            String      @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  accountNumber String
  currency      String      @default("OMR")
  iban          String?
  label         String?
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())

  @@index([bankAccountId])
  @@index([accountNumber])
}

